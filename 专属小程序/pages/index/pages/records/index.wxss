.page {
  min-height: 100vh;
  background: linear-gradient(135deg, #FFF8F1 0%, #FFEBD6 100%);
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #C08A6B;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

.records-scroll {
  height: calc(100vh - 300rpx);
}

.records-container {
  padding-bottom: 120rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

.record-card {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(192, 138, 107, 0.1);
  border: 2rpx solid #FFEBD6;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #FFF8F1;
}

.service-type {
  font-size: 32rpx;
  font-weight: bold;
  color: #C08A6B;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-content {
  margin-bottom: 24rpx;
}

.content-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  background: #FFF8F1;
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #C08A6B;
}

.record-footer {
  display: flex;
  justify-content: flex-end;
}

.status-badge {
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.status-badge.pending {
  background: #FFF0F0;
  color: #FF6B6B;
  border: 2rpx solid #FFE0E0;
}

.status-badge.completed {
  background: #F0FFF0;
  color: #52C41A;
  border: 2rpx solid #E0FFE0;
}

.back-btn-container {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
}

.back-btn {
  background: linear-gradient(135deg, #C08A6B 0%, #A56B4F 100%);
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  height: 88rpx;
  line-height: 88rpx;
}